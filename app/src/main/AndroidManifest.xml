<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.RUN_USER_INITIATED_JOBS" />

    <!-- 主动声明禁用以下权限 -->
    <uses-permission android:name="android.permission.BODY_SENSORS" android:maxSdkVersion="0" />
    <uses-permission android:name="android.permission.BODY_SENSORS_BACKGROUND" android:maxSdkVersion="0" />
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" android:maxSdkVersion="0" />
    <uses-permission android:name="android.permission.MEDIA_CONTENT_CONTROL" android:maxSdkVersion="0" />
    <uses-permission android:name="android.permission.READ_CLIPBOARD" android:maxSdkVersion="0" />
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" android:maxSdkVersion="0" />
    <uses-permission android:name="android.permission.INSTALL_SHORTCUT" android:maxSdkVersion="0" />
    <uses-permission android:name="android.permission.UNINSTALL_SHORTCUT" android:maxSdkVersion="0" />
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" android:maxSdkVersion="0" />
    <uses-permission android:name="android.permission.HIGH_SAMPLING_RATE_SENSORS" android:maxSdkVersion="0" />

    <!-- test分支额外权限：长期后台任务，不合并到main -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.HdrScreenActivator">

        <meta-data
            android:name="android.app.shortcuts"
            android:resource="@xml/shortcuts" />

        <!-- 主界面（步骤一：HDR图片查看器入口） -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleInstance"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden"
            android:theme="@style/Theme.HdrScreenActivator">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

<!-- HDR悬浮窗服务（步骤二） -->
        <service
            android:name=".HdrOverlayService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

        <!-- 快捷设置图块 -->
        <service
            android:name=".HdrTileService"
            android:exported="true"
            android:icon="@drawable/ic_launcher_foreground"
            android:label="HDR悬浮窗"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

    </application>

</manifest>